{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "internal-eval-result.schema.json",
  "type": "object",
  "required": ["eval_run_id", "profile", "recorded_at", "system", "cases", "attempts"],
  "properties": {
    "eval_run_id": {"type": "string"},
    "profile": {"enum": ["smoke", "regression", "release"]},
    "recorded_at": {"type": "string", "format": "date-time"},
    "system": {
      "type": "object",
      "required": ["name", "model", "prompt_version", "tool_environment"]
    },
    "cases": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["attempts", "passed", "failed", "pass_rate"]
      }
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "run", "outcome"]
      }
    }
  }
}
