{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "internal-eval-case.schema.json",
  "type": "object",
  "required": ["id", "level", "phase", "capabilities", "input", "checks"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "level": {"enum": ["L1", "L2"]},
    "phase": {
      "enum": ["Reader", "Bootstrap", "Provision", "Data", "Run", "Validate", "Package"]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "input": {
      "type": "object",
      "required": ["benchmark"],
      "properties": {
        "benchmark": {"type": "string"},
        "override_paper": {"type": "string"}
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "required": ["input"],
            "properties": {"input": {"type": "string"}}
          }
        ]
      }
    },
    "output": {"type": "string"},
    "checks": {"type": "object"}
  }
}
