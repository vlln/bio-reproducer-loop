/*
 * Phase 3: Provision — Nextflow configuration
 */
docker {
    enabled = true
    runOptions = '--platform linux/amd64'
}

params {
    bioconductor_image = 'bench-001-provision:latest'
}

process {
    withLabel: bioconductor {
        container = params.bioconductor_image
    }
}

profiles {
    standard {
        process.executor = 'local'
    }
}