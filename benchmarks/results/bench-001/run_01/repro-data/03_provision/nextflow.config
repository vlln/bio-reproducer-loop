// Phase 3: Provision — Nextflow configuration
// Container engine: Docker (OrbStack)
// Custom image: bio-reproducer:bench-001 (based on bioconductor/bioconductor_docker:RELEASE_3_18)

docker {
    enabled = true
}

process {
    container = 'bio-reproducer:bench-001'

    withLabel: provision {
        errorStrategy = 'terminate'
        maxRetries = 2
        time = '10m'
    }
}

env {
    REPRO_DATA = "${projectDir}/.."
    PLAN_DIR = "${REPRO_DATA}/01_plan"
    BOOTSTRAP_DIR = "${REPRO_DATA}/02_bootstrap"
    PROVISION_DIR = "${REPRO_DATA}/03_provision"
}