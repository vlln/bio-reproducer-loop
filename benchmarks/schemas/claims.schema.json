{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claims.schema.json",
  "type": "object",
  "required": ["id", "paper_title", "paper_doi", "experimental_design", "methods", "quantitative_results", "conclusions", "data_availability"],
  "properties": {
    "id": {"type": "string", "pattern": "^bench-[0-9]{3}$"},
    "paper_title": {"type": "string", "minLength": 1},
    "paper_doi": {"type": "string", "minLength": 1},
    "experimental_design": {"$ref": "#/$defs/claim_list"},
    "methods": {"$ref": "#/$defs/claim_list"},
    "quantitative_results": {"$ref": "#/$defs/claim_list"},
    "figures": {"$ref": "#/$defs/claim_list"},
    "conclusions": {"$ref": "#/$defs/claim_list"},
    "data_availability": {"$ref": "#/$defs/claim_list"},
    "input_conditions": {"$ref": "#/$defs/claim_list"}
  },
  "additionalProperties": false,
  "$defs": {
    "claim_list": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/claim"}
    },
    "claim": {
      "type": "object",
      "required": ["claim_id", "description", "source"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "details": {"type": "object"}
      },
      "additionalProperties": false
    }
  }
}
