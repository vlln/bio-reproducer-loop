{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bundle.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entry_id", "level", "input_root", "primary_paper", "resources"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "entry_id": {"type": "string", "pattern": "^bench-[0-9]{3}$"},
    "level": {"enum": ["L3", "L4", "L5"]},
    "input_root": {"const": "input"},
    "primary_paper": {"type": "string", "minLength": 1},
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/resource"}
    }
  },
  "$defs": {
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "authority", "availability"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "role": {"enum": ["paper", "supplementary", "code", "data", "metadata", "environment", "resource_page"]},
        "authority": {"enum": ["original", "derived"]},
        "availability": {"enum": ["bundled", "external", "restricted", "unavailable", "not_applicable"]},
        "path": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "retrieved_at": {"type": "string", "format": "date-time"},
        "media_type": {"type": "string", "minLength": 3},
        "license": {"type": "string", "minLength": 1},
        "derived_from": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "transform": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tool", "version"],
          "properties": {
            "tool": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "command": {"type": "string", "minLength": 1},
            "script": {"type": "string", "minLength": 1}
          },
          "anyOf": [{"required": ["command"]}, {"required": ["script"]}]
        },
        "checked_at": {"type": "string", "format": "date-time"},
        "access_notes": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"authority": {"const": "original"}}, "required": ["authority"]},
          "then": {"required": ["source"]}
        },
        {
          "if": {"properties": {"authority": {"const": "derived"}}, "required": ["authority"]},
          "then": {"required": ["derived_from", "transform"]}
        },
        {
          "if": {"properties": {"availability": {"const": "bundled"}}, "required": ["availability"]},
          "then": {"required": ["path", "sha256", "media_type"]},
          "else": {"not": {"anyOf": [{"required": ["path"]}, {"required": ["sha256"]}]}}
        },
        {
          "if": {
            "properties": {
              "availability": {"const": "bundled"},
              "authority": {"const": "original"}
            },
            "required": ["availability", "authority"]
          },
          "then": {"required": ["retrieved_at"]}
        },
        {
          "if": {
            "properties": {"availability": {"enum": ["restricted", "unavailable"]}},
            "required": ["availability"]
          },
          "then": {"required": ["checked_at", "access_notes"]}
        }
      ]
    }
  }
}
