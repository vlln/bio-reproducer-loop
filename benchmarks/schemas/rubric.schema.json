{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rubric.schema.json",
  "type": "object",
  "required": ["id", "benchmark_version", "oracle_version", "checks"],
  "properties": {
    "id": {"type": "string"},
    "benchmark_version": {"type": "string"},
    "oracle_version": {"type": "string"},
    "expected_verdict": {
      "enum": ["REPRODUCED", "PARTIAL", "FAILED", "BLOCKED"]
    },
    "verdict_match_threshold": {"type": "number", "minimum": 0, "maximum": 1},
    "verdict_thresholds": {
      "type": "object",
      "properties": {
        "reproduced": {"type": "number", "minimum": 0, "maximum": 100},
        "partial": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "evidence", "comparison", "weight"],
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "evidence": {
            "type": "object",
            "properties": {
              "artifact_role": {"type": "string"},
              "artifact_id": {"type": "string"},
              "alternatives": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["artifact_role"],
                  "properties": {
                    "artifact_role": {"type": "string"},
                    "artifact_id": {"type": "string"},
                    "comparison": {
                      "type": "object",
                      "required": ["comparator"]
                    }
                  }
                }
              }
            },
            "anyOf": [
              {"required": ["artifact_role"]},
              {"required": ["alternatives"]}
            ]
          },
          "comparison": {
            "type": "object",
            "required": ["comparator"],
            "properties": {
              "comparator": {
                "enum": ["file_nonempty", "png_valid", "csv_shape", "csv_row", "csv_rows", "csv_count", "csv_set_overlap", "text_regex", "python_verify"]
              }
            }
          },
          "weight": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    }
  }
}
